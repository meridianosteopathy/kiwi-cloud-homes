# When true (default), the Hostaway client returns mock data.
# Set to "false" once real Hostaway credentials are wired in.
HOSTAWAY_USE_MOCK=true

# Hostaway API credentials (only required when HOSTAWAY_USE_MOCK=false).
# Dashboard: Settings -> API -> create new API key.
# https://api.hostaway.com/documentation
HOSTAWAY_ACCOUNT_ID=
HOSTAWAY_CLIENT_ID=
HOSTAWAY_CLIENT_SECRET=

# Optional. The single listing to display. If unset, the client picks the
# first listing returned by GET /v1/listings (fine for single-property accounts).
HOSTAWAY_LISTING_ID=

# Optional override (defaults to https://api.hostaway.com/v1).
# Useful for sandboxes or local proxies.
HOSTAWAY_API_BASE=
