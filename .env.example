# When true (default), the Hostaway client returns mock data.
# Set to "false" once real Hostaway credentials are wired in.
HOSTAWAY_USE_MOCK=true

# Hostaway API credentials (only required when HOSTAWAY_USE_MOCK=false).
# Dashboard: Settings -> API -> create new API key.
# https://api.hostaway.com/documentation
HOSTAWAY_ACCOUNT_ID=
HOSTAWAY_CLIENT_ID=
HOSTAWAY_CLIENT_SECRET=

# Optional. The single listing to display. If unset, the client picks the
# first listing returned by GET /v1/listings (fine for single-property accounts).
HOSTAWAY_LISTING_ID=

# Optional override (defaults to https://api.hostaway.com/v1).
# Useful for sandboxes or local proxies.
HOSTAWAY_API_BASE=

# Inbox where the "Send inquiry" form delivers guest messages.
# Used to build a mailto: link on the property page — not a secret.
INQUIRY_EMAIL=

# Transactional email — confirmation messages after a booking is created.
# Provider: Brevo (https://brevo.com). Free tier: 300/day, multiple sender
# domains. Verify your sending domain in Brevo → paste the DNS records
# straight into GoDaddy. See EMAIL.md for the walkthrough.
BREVO_API_KEY=
# The "From" address shown to guests. Must be on a verified domain in Brevo.
EMAIL_FROM_ADDRESS=
# Optional: where guest replies are routed. Defaults to EMAIL_FROM_ADDRESS.
EMAIL_REPLY_TO=

# Stripe keys for the booking checkout. Start in TEST mode.
# Dashboard: stripe.com -> Developers -> API keys (toggle "Test mode" on).
# - Publishable key (pk_test_...) is exposed to the browser, prefixed NEXT_PUBLIC_.
# - Secret key (sk_test_...) is server-only and MUST NOT be prefixed NEXT_PUBLIC_.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=

# Stripe webhook signing secret. Verifies incoming webhook bodies came from
# Stripe before we create the corresponding Hostaway reservation.
#
# Local dev: install Stripe CLI (`brew install stripe/stripe-cli/stripe`),
# run `stripe login`, then in a separate terminal:
#   stripe listen --forward-to localhost:3000/api/booking/webhook
# It will print "Your webhook signing secret is whsec_..." — that's the value.
#
# Production: stripe.com -> Developers -> Webhooks -> Add endpoint
#   URL:    https://YOUR-DOMAIN/api/booking/webhook
#   Events: payment_intent.succeeded
# Copy the "Signing secret" from the endpoint detail page.
STRIPE_WEBHOOK_SECRET=
